# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL or MySQL connection string
# Format: postgresql://user:password@localhost:5432/dbname
# or: mysql://user:password@localhost:3306/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/fashion_db

# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Next.js web app (prefix with NEXT_PUBLIC_ so the browser can read it)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SECRET_KEY=sk_test_...

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port the API server runs on
PORT=4000

# Node environment
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origin for CORS requests (web app URL)
CORS_ORIGIN=http://localhost:3000

# ============================================
# WEB APP CONFIGURATION
# ============================================
# URL of the Railway API (set on Vercel)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
