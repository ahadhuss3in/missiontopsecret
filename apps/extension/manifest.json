{
  "manifest_version": 3,
  "name": "FashionFit - Outfit Builder",
  "version": "1.0.0",
  "description": "Build outfits from any fashion website",
  "permissions": ["storage", "activeTab", "cookies"],
  "host_permissions": [
    "https://www.zara.com/*",
    "https://www2.hm.com/*",
    "https://www.asos.com/*",
    "https://www.shein.com/*",
    "https://www.nike.com/*",
    "http://localhost:4000/*",
    "https://api.fashionfit.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zara.com/*",
        "https://www2.hm.com/*",
        "https://www.asos.com/*",
        "https://www.shein.com/*",
        "https://www.nike.com/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["mannequin/body-silhouette.png"],
      "matches": [
        "https://www.zara.com/*",
        "https://www2.hm.com/*",
        "https://www.asos.com/*",
        "https://www.shein.com/*",
        "https://www.nike.com/*"
      ]
    }
  ]
}
