            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Black Casual T-Shirt\",\n  \"description\": \"Comfortable black cotton t-shirt\",\n  \"price\": 49.99,\n  \"imageUrl\": \"https://example.com/tshirt.jpg\",\n  \"url\": \"https://store.com/tshirt\",\n  \"source\": \"asos\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        }
